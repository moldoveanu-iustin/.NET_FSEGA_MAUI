<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Moldoveanu_Iustin_Lab7.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Moldoveanu_Iustin_Lab7"
    Shell.FlyoutBehavior="Disabled"
    Title="Moldoveanu_Iustin_Lab7"
    BackgroundColor="white">

    <Shell.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFDEE9" Offset="0.0" />
            <GradientStop Color="#B5FFFC" Offset="1.0" />
        </LinearGradientBrush>
    </Shell.Background>

    <TabBar>
        <ShellContent
            Title="WELCOME"
            ContentTemplate="{DataTemplate local:MainPage}"
        />
        <ShellContent
            Title="ABOUT"
            ContentTemplate="{DataTemplate local:AboutPage}"
        />
        <ShellContent
            Title="MY SHOPPING LISTS"
            ContentTemplate="{DataTemplate local:ListEntryPage}"
        />
    </TabBar>

</Shell>
